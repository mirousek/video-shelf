VS_DEBUG=true
VS_ENV=dev

# Redis -- used as Celery broker for local dev (on EC2, SQS is used instead)
VS_REDIS_URL=redis://localhost:6379/0

# S3 storage (set to false to use local filesystem only)
VS_USE_S3=false
VS_MAX_UPLOAD_SIZE_MB=2048

# All AWS resource names are derived from VS_ENV automatically:
#   DynamoDB: videoshelf-{env}-projects, videoshelf-{env}-jobs
#   SQS:      videoshelf-{env}
#   S3:       videoshelf-{env}-media
# Override any individual name if needed:
# VS_DYNAMODB_PROJECTS_TABLE=custom-table-name
# VS_S3_BUCKET=custom-bucket-name

# AWS credentials + region: configure via `aws configure` or set standard env vars:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-west-1
