VS_DEBUG=true

# AWS region (used for DynamoDB, SQS, S3)
VS_AWS_REGION=eu-west-1

# DynamoDB table names
VS_DYNAMODB_PROJECTS_TABLE=videoshelf-projects
VS_DYNAMODB_JOBS_TABLE=videoshelf-jobs

# Redis -- used as Celery broker for local dev (on EC2, SQS is used instead)
VS_REDIS_URL=redis://localhost:6379/0

# S3 storage (set to false to use local filesystem only)
VS_USE_S3=false
VS_S3_BUCKET=videoshelf
# Leave empty to use IAM / ~/.aws/credentials
VS_S3_ACCESS_KEY=
VS_S3_SECRET_KEY=

VS_MAX_UPLOAD_SIZE_MB=2048
